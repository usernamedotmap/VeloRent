{
  "compilerOptions": {
    "target":           "ES2020",
    "lib":              ["ES2020", "DOM", "DOM.Iterable"],
    "module":           "ESNext",
    "moduleResolution": "bundler",
    "allowImportingTsExtensions": true,
    "resolveJsonModule": true,
    "isolatedModules": true,
    
    "jsx":              "react-jsx",
    "strict":           true,
    "outDir": "./dist",
    "noEmit": true,
    "allowJs": true,
    "paths": {
      "@/*": ["./src/*"]
    },
    "skipLibCheck":     true,
    "esModuleInterop":  true
  },
  "exclude": ["node_modules", "dist"],
  "include": ["src"]
}